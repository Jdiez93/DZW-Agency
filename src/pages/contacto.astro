---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contacto · DZW Agency"
  description="Diseño web, desarrollo, mantenimiento, hosting y soluciones digitales profesionales."
>
  <section class="reveal fade-up max-w-4xl mx-auto px-6 py-24">
    <!-- TÍTULO -->
    <div class="text-center mb-16 hero-fade-up">
      <h1 class="text-4xl md:text-5xl font-extrabold">Hablemos de tu proyecto</h1>

      <p class="mt-6 text-slate-300 text-lg max-w-2xl mx-auto leading-relaxed">
        Cuéntanos qué tipo de página web necesitas, en qué punto está tu negocio y qué objetivo quieres conseguir.
        Te responderemos con una propuesta clara, sin tecnicismos y sin compromiso.
      </p>
    </div>

    <!-- FORMULARIO AMPLIO -->
    <form
      id="contact-form"
      class="reveal fade-up space-y-6 bg-slate-900/40 p-8 rounded-2xl border border-blue-500/20 shadow-lg"
    >
      <!-- Campo invisible anti-spam -->
      <input type="text" name="honeypot" class="hidden" />

      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label for="name" class="text-sm text-slate-300">Nombre</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:border-blue-500 focus:outline-none"
          />
        </div>

        <div class="space-y-2">
          <label for="email" class="text-sm text-slate-300">Correo electrónico</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:border-blue-500 focus:outline-none"
          />
        </div>
      </div>

      <div class="space-y-2">
        <label for="service" class="text-sm text-slate-300">Servicio deseado</label>
        <select
          id="service"
          name="service"
          required
          class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:border-blue-500 focus:outline-none"
        >
          <option value="Página web básica">Página web básica</option>
          <option value="Página web profesional">Página web profesional</option>
          <option value="Tienda online">Tienda online</option>
          <option value="Mantenimiento">Mantenimiento</option>
          <option value="Hosting">Hosting</option>
          <option value="Otro">Otro</option>
        </select>
      </div>

      <div class="space-y-2">
        <label for="message" class="text-sm text-slate-300">Mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:border-blue-500 focus:outline-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-3 rounded-lg bg-blue-600 hover:bg-blue-700 transition text-white font-semibold"
      >
        Enviar mensaje
      </button>
    </form>

    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>



    <!-- INFORMACIÓN EXTRA -->
    <div class="mt-24 text-center space-y-6 hero-fade-up">
      <h2 class="text-xl md:text-2xl font-semibold">¿Prefieres contactar por otra vía?</h2>

      <p class="text-slate-200 text-lg">
        ✉️ <span class="font-mono">jorgediezrodriguez2004@gmail.com</span>
      </p>

      <p class="text-slate-200 text-lg">
        💬 WhatsApp / Teléfono: <span class="font-mono">+34 684 313 491</span>
      </p>

      <p class="text-slate-400 text-sm">
        Horario: lunes a viernes de 9:00 a 16:00 (hora España)
      </p>
    </div>
  </section>

      <script>
      window.addEventListener("load", function () {
        // Comprobamos que EmailJS está cargado
        if (!window.emailjs) {
          console.error("EmailJS no está disponible en window");
          return;
        }

        // Inicializar EmailJS con tu PUBLIC KEY
        emailjs.init("QZXH9OenHPoxDIcaB");

        const form = document.getElementById("contact-form");
        if (!form) return;

        form.addEventListener("submit", function (e) {
          e.preventDefault();

          // Anti-spam
          if (form.honeypot.value !== "") return;

          const SERVICE_ID = "service_q8no5ew";
          const TEMPLATE_ID = "template_yt3f9ye";

          emailjs
  .sendForm(SERVICE_ID, TEMPLATE_ID, form)
  .then(function () {
    // Redirigimos a la página de gracias
    window.location.href = "/gracias";
  })
  .catch(function (error) {
    console.error("Error enviando el formulario:", error);
    alert("Hubo un error al enviar tu mensaje. Inténtalo más tarde.");
  });

        });
      });
    </script>

</BaseLayout>
