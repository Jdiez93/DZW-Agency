---
import "../styles/global.css";
const { title = "Agencia Web", description = "Creamos páginas web profesionales." } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo-agencia.jpg" />
    <!-- SEO Básico -->
<meta name="robots" content="index, follow" />
<meta name="author" content="DZW Agency" />
<meta name="theme-color" content="#0f172a" />
<!-- EmailJS global -->
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js" defer></script>
<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="DZW Agency" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content="https://tudominio.com" />
<meta property="og:image" content="https://tudominio.com/preview.jpg" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content="https://tudominio.com/preview.jpg" />

<!-- JSON-LD Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "DZW Agency",
  "url": "https://tudominio.com",
  "description": "Agencia especializada en diseño web, desarrollo, hosting y mantenimiento.",
  "publisher": {
    "@type": "Organization",
    "name": "DZW Agency",
    "logo": {
      "@type": "ImageObject",
      "url": "https://tudominio.com/logo.png"
    }
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": "dzwagency@gmail.com",
    "availableLanguage": ["Spanish"]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "DZW Agency",
  "image": "https://tudominio.com/logo.png",
  "@id": "https://tudominio.com",
  "url": "https://tudominio.com",
  "telephone": "+34XXXYYYZZZ",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "España",
    "addressCountry": "ES"
  },
  "openingHours": "Mo-Fr 09:00-20:00"
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Diseño y desarrollo web",
  "provider": {
    "@type": "Organization",
    "name": "DZW Agency",
    "url": "https://tudominio.com"
  },
  "areaServed": "ES",
  "description": "Creación de páginas web profesionales, mantenimiento, hosting y optimización."
}
</script>

    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body class="bg-slate-900 text-slate-100 antialiased">
    <header
  id="site-header"
  class="fixed top-0 left-0 z-40 w-full bg-slate-900/50 backdrop-blur border-b border-slate-800 transition-all duration-300"
>
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <div class="flex items-center gap-3">
      <img 
        src="/logo-agencia.jpg" 
        alt="Logo DZW AGENCY" 
        class="w-9 h-9 object-cover rounded-md shadow-sm"
      />
      <h1 class="text-xl font-bold tracking-wide">DZW AGENCY</h1>
    </div>

    <!-- Botón menú móvil -->
    <button
      id="mobile-menu-button"
      class="md:hidden inline-flex items-center justify-center p-2 rounded-lg border border-slate-600 hover:border-blue-500 hover:bg-slate-800/80 transition"
      aria-label="Abrir menú"
      aria-expanded="false"
      type="button"
    >
      <!-- Icono hamburguesa -->
      <svg id="mobile-menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
      </svg>
      <!-- Icono cerrar -->
      <svg id="mobile-menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <!-- Menú escritorio -->
    <ul class="hidden md:flex gap-8 text-sm items-center">

  <li>
    <a href="/" class="flex items-center gap-2 hover:text-blue-400 transition">
      <svg class="w-5 h-5 menu-icon" fill="none" stroke="currentColor" stroke-width="2"
           viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 12l2-2m0 0l7-7 7 7m-9 2v10m4-10v10m-9 10h14"/>
      </svg>
      Inicio
    </a>
  </li>

  <li>
    <a href="/servicios" class="flex items-center gap-2 hover:text-blue-400 transition">
      <svg class="w-5 h-5 menu-icon" fill="none" stroke="currentColor" stroke-width="2"
