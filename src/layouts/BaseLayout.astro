    <!-- CONTACTO -->
<div class="space-y-6">
  <h4 class="text-lg font-semibold">Contacto</h4>

  <ul class="space-y-4 text-slate-300 text-sm">

    <!-- UBICACIÓN -->
    <li class="flex items-center gap-3">
      <div class="w-9 h-9 flex items-center justify-center rounded-lg bg-blue-500/10 border border-blue-500/20">
        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" stroke-width="2"
             viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm0 1c-5 0-9 2.5-9 5v2h18v-2c0-2.5-4-5-9-5z"/>
        </svg>
      </div>
      <span class="text-slate-300">España</span>
    </li>

    <!-- EMAIL -->
   <li class="flex items-center gap-3">
  <div class="w-9 h-9 flex items-center justify-center rounded-lg bg-blue-500/10 border border-blue-500/20">
    <svg
      class="w-5 h-5 text-blue-400"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8"
      />
      <rect
        x="3"
        y="5"
        width="18"
        height="14"
        rx="2"
        ry="2"
      />
    </svg>
  </div>
  <span class="text-slate-300 break-words">jorgediezrodriguez2004@gmail.com</span>
</li>


    <!-- TELÉFONO -->
    <li class="flex items-center gap-3">
      <div class="w-9 h-9 flex items-center justify-center rounded-lg bg-blue-500/10 border border-blue-500/20">
        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" stroke-width="2"
             viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M22 16.92v3a2 2 0 0 1-2.18 2A19.72 19.72 0 0 1 3.09 5.18 2 2 0 0 1 5.11 3h3a2 2 0 0 1 2 1.72 12.9 12.9 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11l-1.27 1.27a16 16 0 0 0 6.86 6.86l1.27-1.27a2 2 0 0 1 2.11-.45 12.9 12.9 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      </div>
      <span class="text-slate-300">+34 684 313 491</span>
    </li>

  </ul>
</div>


  <!-- COPYRIGHT -->
  <div class="border-t border-slate-800 mt-12 pt-6 text-center text-slate-500 text-xs">
    © {new Date().getFullYear()} DZW AGENCY — Todos los derechos reservados.
  </div>
</footer>

<script>
  if (typeof window !== "undefined") {
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("mobile-menu-icon-open");
    const iconClose = document.getElementById("mobile-menu-icon-close");
    const header = document.getElementById("site-header");

    // Toggle menú móvil
    if (button && menu && iconOpen && iconClose) {
      button.addEventListener("click", () => {
        const isHidden = menu.classList.contains("hidden");

        if (isHidden) {
          menu.classList.remove("hidden");
          button.setAttribute("aria-expanded", "true");
          iconOpen.classList.add("hidden");
          iconClose.classList.remove("hidden");
        } else {
          menu.classList.add("hidden");
          button.setAttribute("aria-expanded", "false");
          iconOpen.classList.remove("hidden");
          iconClose.classList.add("hidden");
        }
      });
    }

    // Efecto de scroll en el header
    if (header) {
      const handleScroll = () => {
        if (window.scrollY > 10) {
          header.classList.add("header-scrolled");
        } else {
          header.classList.remove("header-scrolled");
        }
      };

      handleScroll();
      window.addEventListener("scroll", handleScroll);
    }

    // ⭐ Resaltar página activa
    const currentPath = window.location.pathname;

    document.querySelectorAll("a[data-path]").forEach((link) => {
      const linkPath = link.getAttribute("data-path");

      if (linkPath === currentPath) {
        link.classList.add("nav-active");
      }
    });
  }

  // ===========================
// REVEAL ON SCROLL
// ===========================
const revealElements = document.querySelectorAll('.reveal');

const revealObserver = new IntersectionObserver(
  (entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      } else {
        entry.target.classList.remove('visible'); // vuelve a ocultarse al subir
      }
    });
  },
  {
    threshold: 0.15, // 15% del elemento debe verse para activarse
    rootMargin: "0px 0px -5% 0px"
  }
);

revealElements.forEach((el) => revealObserver.observe(el));

</script>



  </body>
</html>
