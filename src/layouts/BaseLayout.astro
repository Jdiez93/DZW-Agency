      </svg>
      Servicios
    </a>
  </li>

  <li>
    <a href="/sobre-nosotros" class="flex items-center gap-2 hover:text-blue-400 transition">
      <svg class="w-5 h-5 menu-icon" fill="none" stroke="currentColor" stroke-width="2"
           viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14c-4 0-7 2-7 5v1h14v-1c0-3-3-5-7-5z"/>
      </svg>
      Nosotros
